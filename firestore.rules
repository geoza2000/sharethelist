rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isHouseholdMember(householdId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if false;
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'settings',
          'activeHouseholdId',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    // Households collection - reads for members, writes via Cloud Functions
    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow create, update, delete: if false;

      // Shops subcollection - full access for household members
      match /shops/{shopId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      // Products subcollection - full access for household members
      match /products/{productId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      // Items subcollection - full access for household members
      match /items/{itemId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }

    // Invitations - all access through Cloud Functions (Admin SDK)
    match /invitations/{invitationId} {
      allow read, write: if false;
    }
  }
}
